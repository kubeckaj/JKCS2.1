#!/bin/bash -norc
source ~/.JKCSusersetup.txt
scriptpath="$( cd "$(dirname "$0")" ; pwd -P )"
toolspath="$scriptpath/../../JKTS/src"
INPUT="$@"
echo "COMMAND: $(basename $0) $@" >> "${PWD}/output"

# Default values
PYTHON_ARGS=()
XYZ=0
PKL=0
INFO=0
RESTART=0
COLLECT=0
PICKLE=0
SKIP_REACTANTS=0
SKIP_PRODUCTS=0
SKIP_TS=0

for arg in "$@"; do
  PYTHON_ARGS+=("$arg")
done
if [[ "$SBATCH_PREFIX" =~ [^[:space:]] ]]; then
  # If SBATCH_PREFIX contains non-space characters, add it to PYTHON_ARGS
  PYTHON_ARGS+=("$SBATCH_PREFIX")
fi

for arg in "$@"; do
  case "$arg" in
    -h|--help|-help)
      program_PYTHON "$toolspath/main.py" -h
      exit 0
      ;;
    -loc|-collect)
      program_PYTHON "$toolspath/main.py" "${PYTHON_ARGS[@]}" | tee -a "${PWD}/output"
      exit 0
      ;;
    -test|-info|-pickle|-init|-plot|-movie|-rate)
      program_PYTHON "$toolspath/main.py" "${PYTHON_ARGS[@]}"
      exit 0
      ;;
    -reactants)
      SKIP_REACTANTS=1
      ;;
    -products)
      SKIP_PRODUCTS=1
      ;;
    -TS)
      SKIP_TS=1
      ;;
    *.xyz)
      input_file="$arg"
      XYZ=1
      ;;
    -smiles)
      XYZ=1
      ;;
    -restart|-rerun|-IRC)
      RESTART=1
      ;;
    *.pkl)
      PKL=1
      ;;
    *)
      ;;
  esac
done

submit_job() {
  local directory=$1
  local args_string
  args_string=$(printf '%q ' "${PYTHON_ARGS[@]}")
  nohup bash -c "source ~/.JKCSusersetup.txt; program_PYTHON \"$toolspath/main.py\" $args_string" \
    > /dev/null 2>&1 &
  echo "JKTS monitoring started for $directory (PID: $!, log: $PWD/log)"
}


if [[ "$XYZ" -gt 0 ]]; then
  program_PYTHON "$toolspath/main.py" "${PYTHON_ARGS[@]}" -init
  for dir in */; do
      dir_name=${dir%/}
      if { [[ $dir_name =~ _H[0-9]+$ ]] && [[ "$SKIP_TS" -eq 0 ]]; } || { [[ $dir_name == "reactants" ]] && [[ "$SKIP_REACTANTS" -eq 0 ]]; } || { [[ $dir_name == "products" ]] && [[ "$SKIP_PRODUCTS" -eq 0 ]]; }; then
        cd $dir_name
        submit_job "$dir_name"
        cd ..
      fi
  done
elif [ "$RESTART" -gt 0 ]; then
  submit_job $(basename "$PWD")
else
  echo "Incorrect input argument"
fi
